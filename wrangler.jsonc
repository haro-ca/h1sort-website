{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "h1sort-website",
  "compatibility_date": "2026-07-04",
  "main": "worker/index.ts",
  "assets": {
    "binding": "ASSETS",
    "directory": "dist",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
