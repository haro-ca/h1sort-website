---
import Base from '../layouts/Base.astro';

const talks = [
  {
    title: 'Modern Data Stack',
    meta: 'Talk · The DataPub',
    desc: 'An attempt to demystify the word “modern” by going through the historical cycles of technology used in analytics and data engineering.',
    href: 'https://www.youtube.com/watch?v=h5bq3gsDDd0',
    cta: 'Watch',
  },
  {
    title: 'OLAP vs OLTP: Why DuckDB is Awesome',
    meta: 'Talk',
    desc: 'A deep dive into how database systems optimized for analytics workloads (OLAP) differ from those built for transactional workloads (OLTP). Heavy DuckDB advocacy.',
    href: 'https://t.co/7LVVLIhicr',
    cta: 'Watch',
  },
  {
    title: 'Why You Should Study the Insides of DBMS',
    meta: 'Conversation',
    desc: 'With Código Facilito’s CTO on understanding databases at a fundamental level and living a “database-centric” life. Features an Andy Pavlo shoutout.',
    href: 'https://t.co/tYNN2Sx4yV',
    cta: 'Watch',
  },
  {
    title: 'What is Data Science',
    meta: 'Interview',
    desc: 'What data science actually is and how to begin the learning journey, starting with R’s tidyverse; highlights David Robinson’s screencasts as high-signal content.',
    href: 'https://t.co/AdiPMKi89Z',
    cta: 'Watch',
  },
  {
    title: 'What is Data Science',
    meta: 'Soliloquy',
    desc: 'Solo version of the data-science fundamentals talk, without the interview format.',
    href: 'https://t.co/lJioLRiG2w',
    cta: 'Watch',
  },
  {
    title: 'Live Coding: Airflow',
    meta: 'Session',
    desc: 'A practical live session walking through Apache Airflow.',
    href: 'https://t.co/R3QOCC8ORh',
    cta: 'Watch',
  },
  {
    title: 'Value of Data Science in Modern Business',
    meta: 'Talk',
    desc: 'A discussion on the real business value of data science today.',
    href: 'https://t.co/XD4BaF8pQd',
    cta: 'Watch',
  },
  {
    title: 'How APIs Differ Across Data Libraries',
    meta: 'Talk',
    desc: 'How the APIs of different data libraries shape the way you think and work.',
    href: 'https://t.co/KzjQNaAUHk',
    cta: 'Watch',
  },
  {
    title: 'What Defines a Good Data Visualization',
    meta: 'Talk',
    desc: 'The principles that make a data visualization effective.',
    href: 'https://t.co/lUuf46xbJH',
    cta: 'Watch',
  },
  {
    title: 'Snowflake + SageMaker + dbt',
    meta: 'Demo',
    desc: 'End-to-end analytics demo combining Snowflake, SageMaker, and dbt.',
    href: 'https://t.co/OVIj4WrjxN',
    cta: 'View demo',
  },
  {
    title: 'Data Architectures Overview',
    meta: 'Thread',
    desc: 'Overview and discussion of modern data architectures.',
    href: 'https://t.co/hAkbfA8BNg',
    cta: 'View thread',
  },
  {
    title: 'Product Management Fundamentals',
    meta: 'Thread',
    desc: 'What a Product Manager really does, drawing from Marty Cagan’s “Inspired”.',
    href: 'https://t.co/iH1DrOO8jW',
    cta: 'View thread',
  },
];
---

<Base
  title="Talking · Carlos Alberto Haro"
  description="Public talks, live sessions and threads by Carlos Alberto Haro: databases, OLAP vs OLTP, DuckDB, data science, the modern data stack, and product."
  path="/talking"
>
  <section class="page">
    <header class="rule-top">
      <a class="brand link" href="/">
        <svg class="brand-mark" viewBox="0 0 64 40" aria-hidden="true">
          <rect x="2" y="26" width="10" height="12" rx="1.5"></rect>
          <rect x="18" y="16" width="10" height="22" rx="1.5"></rect>
          <rect x="34" y="8" width="10" height="30" rx="1.5"></rect>
          <rect x="50" y="2" width="10" height="36" rx="1.5"></rect>
        </svg>
        <span class="strong">h1sort.com</span>
      </a>
      <span>01 · Talking</span>
    </header>

    <div class="page-content">
      <span class="acid-label reveal d1">Talking</span>
      <h1 class="page-title reveal d2">Out loud, <span class="ital">on record</span>.</h1>
      <p class="page-lede reveal d3">
        Public talks, live sessions and threads: databases, data science,
        and the shape of the modern data stack.
      </p>

      <ol class="talks">
        {talks.map((t, i) => (
          <li class={`talk reveal d${Math.min(4 + i, 8)}`}>
            <span class="talk-n">{String(i + 1).padStart(2, '0')}</span>
            <div class="talk-body">
              <div class="talk-top">
                <h2 class="talk-title">
                  <a href={t.href} target="_blank" rel="noopener noreferrer">{t.title}</a>
                </h2>
                <span class="talk-meta">{t.meta}</span>
              </div>
              <p class="talk-desc">{t.desc}</p>
            </div>
            <a class="talk-cta" href={t.href} target="_blank" rel="noopener noreferrer">
              {t.cta} <span class="talk-arrow">→</span>
            </a>
          </li>
        ))}
      </ol>
    </div>

    <footer class="rule-bottom">
      <span class="strong">Carlos Alberto Haro López</span>
      <a class="link" href="/">← Back to landing</a>
    </footer>
  </section>
</Base>

<style>
  .page {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    padding: clamp(4.5rem, 9vh, 6.5rem) var(--page-padding) clamp(5.5rem, 11vh, 8rem);
    background:
      radial-gradient(circle at 88% 10%, rgba(200, 255, 62, 0.22) 0%, transparent 44%),
      radial-gradient(circle at 4% 96%, rgba(200, 255, 62, 0.12) 0%, transparent 46%),
      var(--bg);
  }
  .brand { display: inline-flex; align-items: center; gap: 0.6em; }
  .brand-mark { width: 1.6em; height: 1em; fill: var(--ink); }
  .ital { font-style: italic; font-weight: 400; }

  .page-content { position: relative; z-index: 2; max-width: 1100px; width: 100%; margin: 0 auto; }
  .page-title {
    font-family: var(--font-serif); font-weight: 900;
    font-size: var(--display-size); line-height: 0.9; letter-spacing: -0.03em;
    margin: clamp(1rem, 2.5vh, 1.6rem) 0 clamp(0.8rem, 2vh, 1.2rem);
    font-variation-settings: "opsz" 144;
  }
  .page-lede {
    font-family: var(--font-serif); font-style: italic; font-weight: 300;
    font-size: var(--tagline-size); line-height: 1.5; color: var(--muted); max-width: 48ch;
  }

  .talks {
    list-style: none;
    margin: clamp(2rem, 5vh, 3.5rem) 0 0;
    padding: 0;
    border-top: 1px solid var(--ink);
  }
  .talk {
    display: flex;
    align-items: baseline;
    gap: clamp(0.9rem, 2vw, 1.6rem);
    padding: clamp(1.1rem, 2.4vh, 1.6rem) 0;
    border-bottom: 1px solid var(--rule);
    position: relative;
  }
  .talk::before {
    content: ''; position: absolute; top: -1px; left: 0;
    width: 0; height: 2px; background: var(--acid);
    transition: width 0.4s var(--ease);
  }
  .talk:hover::before { width: 100%; }
  .talk-n {
    font-family: var(--font-mono);
    font-size: var(--label-size);
    letter-spacing: 0.18em;
    color: var(--muted);
  }
  .talk-body { flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
  .talk-top { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .talk-title {
    font-family: var(--font-serif); font-weight: 700;
    font-size: clamp(1.15rem, 2vw, 1.7rem); letter-spacing: -0.02em;
    margin: 0;
  }
  /* marker-style sweep on row hover (same recipe as .marker in global.css) */
  .talk-title a {
    color: inherit;
    background: linear-gradient(180deg, transparent 58%, var(--acid) 58%, var(--acid) 92%, transparent 92%);
    background-size: 0% 100%;
    background-repeat: no-repeat;
    padding: 0 0.08em;
    margin-left: -0.08em;
    transition: background-size 0.5s var(--ease);
  }
  .talk:hover .talk-title a { background-size: 100% 100%; }
  .talk-meta {
    font-family: var(--font-mono);
    font-size: var(--label-size);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .talk-desc {
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    color: var(--muted);
    line-height: 1.55;
    max-width: 62ch;
    margin: 0;
  }
  .talk-cta {
    font-family: var(--font-mono);
    font-size: var(--label-size);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
    align-self: baseline;
  }
  .talk-cta:hover { color: var(--acid-deep); }
  .talk-arrow { color: var(--acid-deep); display: inline-block; transition: transform 0.35s var(--ease); }
  .talk-cta:hover .talk-arrow { transform: translate(4px, -4px); }

  @media (max-width: 720px) {
    .talk { flex-wrap: wrap; }
    .talk-n { flex-basis: 100%; }
    .talk-cta { margin-left: 0; }
    .page-lede { max-width: none; }
  }
</style>
