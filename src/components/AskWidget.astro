---
// Floating site assistant — chats with /api/chat (Claude Haiku behind a
// Cloudflare Pages Function). Vanilla TS, Editorial Acid styling.
---

<button class="ask-launch" id="askLaunch" aria-expanded="false" aria-controls="askPanel">
  <span class="ask-dot" aria-hidden="true"></span> Ask
</button>

<section class="ask-panel" id="askPanel" role="dialog" aria-label="Site assistant" hidden>
  <header class="ask-head">
    <span class="ask-title"><span class="ask-dot" aria-hidden="true"></span> Assistant</span>
    <button class="ask-close" id="askClose" aria-label="Close assistant">×</button>
  </header>
  <div class="ask-log" id="askLog" aria-live="polite">
    <p class="ask-msg ask-msg-a">Hi! Ask me anything about Carlos — his work, CV, teaching, or how to reach him.</p>
  </div>
  <form class="ask-form" id="askForm">
    <input
      class="ask-input"
      id="askInput"
      type="text"
      placeholder="Ask a question…"
      autocomplete="off"
      maxlength="1000"
      aria-label="Your question"
    />
    <button class="ask-send" type="submit" aria-label="Send">→</button>
  </form>
</section>

<style>
  .ask-launch {
    position: fixed;
    right: var(--page-padding);
    bottom: clamp(4rem, 9vh, 6rem);
    z-index: 120;
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    font-family: var(--font-mono);
    font-size: var(--label-size);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--bg);
    border: 1px solid var(--ink);
    padding: clamp(0.5rem, 1.1vh, 0.75rem) clamp(0.9rem, 1.5vw, 1.3rem);
    cursor: pointer;
    transition: background 0.35s var(--ease), transform 0.35s var(--ease);
  }
  .ask-launch:hover { background: var(--acid); transform: translateY(-2px); }

  .ask-dot {
    width: 0.55em;
    height: 0.55em;
    border-radius: 50%;
    background: var(--acid-deep);
  }

  .ask-panel {
    position: fixed;
    right: var(--page-padding);
    bottom: clamp(4rem, 9vh, 6rem);
    z-index: 130;
    width: min(380px, calc(100vw - 2 * var(--page-padding)));
    height: min(540px, 72vh);
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--ink);
    box-shadow: 8px 8px 0 var(--acid);
  }
  .ask-panel[hidden] { display: none; }

  .ask-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--ink);
  }
  .ask-title {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    font-family: var(--font-mono);
    font-size: var(--label-size);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .ask-close {
    border: none;
    background: none;
    font-size: 1.3rem;
    line-height: 1;
    color: var(--muted);
    cursor: pointer;
  }
  .ask-close:hover { color: var(--ink); }

  .ask-log {
    flex: 1;
    overflow-y: auto;
    padding: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .ask-msg {
    font-size: clamp(0.85rem, 1.05vw, 0.95rem);
    line-height: 1.5;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    max-width: 90%;
  }
  .ask-msg-a { color: var(--ink); align-self: flex-start; }
  .ask-msg-u {
    align-self: flex-end;
    background: var(--acid);
    color: var(--ink);
    padding: 0.4rem 0.65rem;
  }
  .ask-msg-err { color: #a03418; font-family: var(--font-mono); font-size: 0.75rem; }
  .ask-msg-a.thinking::after { content: '▌'; color: var(--acid-deep); animation: ask-blink 1s steps(2) infinite; }
  @keyframes ask-blink { 50% { opacity: 0; } }

  .ask-form {
    display: flex;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    border-top: 1px solid var(--rule);
  }
  .ask-input {
    flex: 1;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--ink);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--rule);
    padding: 0.3rem 0.1rem;
    outline: none;
  }
  .ask-input:focus { border-bottom-color: var(--acid-deep); }
  .ask-send {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--ink);
    border: 1px solid var(--ink);
    background: transparent;
    padding: 0.2rem 0.7rem;
    cursor: pointer;
    transition: background 0.3s var(--ease);
  }
  .ask-send:hover:not(:disabled) { background: var(--acid); }
  .ask-send:disabled { opacity: 0.4; cursor: default; }
</style>

<script>
  const launch = document.getElementById('askLaunch') as HTMLButtonElement | null;
  const panel = document.getElementById('askPanel') as HTMLElement | null;
  const closeBtn = document.getElementById('askClose') as HTMLButtonElement | null;
  const log = document.getElementById('askLog') as HTMLElement | null;
  const form = document.getElementById('askForm') as HTMLFormElement | null;
  const input = document.getElementById('askInput') as HTMLInputElement | null;

  if (launch && panel && closeBtn && log && form && input) {
    const history: { role: 'user' | 'assistant'; content: string }[] = [];
    let busy = false;

    const setOpen = (open: boolean) => {
      panel.hidden = !open;
      launch.hidden = open;
      launch.setAttribute('aria-expanded', String(open));
      if (open) input.focus();
    };
    launch.addEventListener('click', () => setOpen(true));
    closeBtn.addEventListener('click', () => setOpen(false));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.hidden) setOpen(false);
    });

    const addMsg = (cls: string, text: string): HTMLParagraphElement => {
      const p = document.createElement('p');
      p.className = `ask-msg ${cls}`;
      p.textContent = text;
      log.appendChild(p);
      log.scrollTop = log.scrollHeight;
      return p;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q || busy) return;
      busy = true;
      (form.querySelector('.ask-send') as HTMLButtonElement).disabled = true;
      input.value = '';

      addMsg('ask-msg-u', q);
      history.push({ role: 'user', content: q });
      const out = addMsg('ask-msg-a thinking', '');

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ messages: history }),
        });
        if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';
        let answer = '';
        for (;;) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() ?? '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            let event;
            try { event = JSON.parse(line.slice(6)); } catch { continue; }
            if (event.type === 'content_block_delta' && event.delta?.type === 'text_delta') {
              answer += event.delta.text;
              out.textContent = answer;
              log.scrollTop = log.scrollHeight;
            }
            if (event.type === 'error') throw new Error(event.error?.message ?? 'stream error');
          }
        }
        history.push({ role: 'assistant', content: answer });
      } catch {
        out.remove();
        history.pop();
        addMsg('ask-msg-err', 'Something went wrong — try again in a moment.');
      } finally {
        out.classList.remove('thinking');
        busy = false;
        (form.querySelector('.ask-send') as HTMLButtonElement).disabled = false;
      }
    });
  }
</script>
