---
export interface Props {
  section: string;
  title: string;
  blurb: string;
  tag?: string;
  back?: string;
  backLabel?: string;
  status?: string;
}
const {
  section,
  title,
  blurb,
  tag = '',
  back = '/',
  backLabel = 'Back to landing',
  status = 'In progress — building this out next',
} = Astro.props;
---

<section class="cs">
  <header class="rule-top">
    <a class="brand link" href="/">
      <svg class="brand-mark" viewBox="0 0 64 40" aria-hidden="true">
        <rect x="2" y="26" width="10" height="12" rx="1.5"></rect>
        <rect x="18" y="16" width="10" height="22" rx="1.5"></rect>
        <rect x="34" y="8" width="10" height="30" rx="1.5"></rect>
        <rect x="50" y="2" width="10" height="36" rx="1.5"></rect>
      </svg>
      <span class="strong">h1sort.com</span>
    </a>
    <span>{tag}</span>
  </header>

  <div class="cs-content">
    <span class="acid-label reveal d1">{section}</span>
    <h1 class="cs-title reveal d2">{title}</h1>
    <p class="cs-blurb reveal d3">{blurb}</p>
    <div class="cs-status reveal d4">
      <span class="cs-dot"></span> {status}
    </div>
    <a class="btn reveal d5" href={back}><span class="arrow">←</span> {backLabel}</a>
  </div>

  <footer class="rule-bottom">
    <span class="strong">Carlos Alberto Haro López</span>
    <a class="link" href="mailto:haro_ca@outlook.com">haro_ca@outlook.com</a>
  </footer>
</section>

<style>
  .cs {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(4.5rem, 9vh, 6.5rem) var(--page-padding);
    background:
      radial-gradient(circle at 88% 12%, rgba(200, 255, 62, 0.22) 0%, transparent 44%),
      radial-gradient(circle at 6% 96%, rgba(200, 255, 62, 0.12) 0%, transparent 46%),
      var(--bg);
  }
  .brand { display: inline-flex; align-items: center; gap: 0.6em; }
  .brand-mark { width: 1.6em; height: 1em; fill: var(--ink); }

  .cs-content {
    position: relative;
    z-index: 2;
    max-width: 46ch;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(1rem, 2.5vh, 1.6rem);
  }
  .cs-title {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: var(--display-size);
    line-height: 0.9;
    letter-spacing: -0.03em;
    font-variation-settings: "opsz" 144;
  }
  .cs-blurb {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 300;
    font-size: var(--tagline-size);
    line-height: 1.5;
    color: var(--muted);
  }
  .cs-status {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    font-family: var(--font-mono);
    font-size: var(--label-size);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .cs-dot {
    width: 0.55em; height: 0.55em; border-radius: 50%;
    background: var(--acid-deep);
    animation: live-pulse 1.5s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(0.7); }
  }
</style>
