---
import '../styles/global.css';
import AskWidget from '../components/AskWidget.astro';

export interface Props {
  title?: string;
  description?: string;
  /** Path for canonical/OG url, e.g. "/cv" */
  path?: string;
}

const {
  title = 'Carlos Alberto Haro · AI Engineer & Technical Product Manager',
  description = 'Carlos Alberto Haro López, AI Engineer & Technical Product Manager. 8+ years designing and shipping end-to-end data & AI solutions across AWS, Azure and GCP.',
  path = '/',
} = Astro.props;

// Pages are served as directories, so canonical URLs always end in a slash.
const canonical = new URL(path.endsWith('/') ? path : `${path}/`, Astro.site ?? 'https://h1sort.com').toString();
const ogImage = new URL('/og.png', Astro.site ?? 'https://h1sort.com').toString();

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Carlos Alberto Haro López',
  alternateName: 'Carlos Haro',
  jobTitle: 'AI Engineer & Technical Product Manager',
  url: 'https://h1sort.com/',
  email: 'mailto:carlos@h1sort.com',
  address: { '@type': 'PostalAddress', addressLocality: 'Mexico City', addressCountry: 'MX' },
  sameAs: [
    'https://github.com/haro-ca',
    'https://www.linkedin.com/in/h1sort',
    'https://x.com/h1sort',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Runs before first paint: gates the hidden pre-reveal state so no-JS visitors see full content -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="h1sort" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Carlos Haro, AI Engineer & Technical Product Manager · h1sort.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(person)} />

    <!-- Fonts: Fraunces + IBM Plex Mono + Work Sans — self-hosted (src/styles/fonts.css), preload the above-the-fold trio -->
    <link rel="preload" href="/fonts/fraunces-normal-900-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/work-sans-normal-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ibm-plex-mono-normal-400-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <slot />
    <AskWidget />

    <script>
      // Global reveal-on-scroll observer for any [class~="reveal"] element.
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
